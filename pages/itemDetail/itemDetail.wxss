.detail-page {
  min-height: 100vh;
  background: #f2f5f8;
  position: relative;
}

.gallery {
  width: 100%;
  height: 560rpx;
  background: #eef1f5;
}

.gallery-img {
  width: 100%;
  height: 100%;
}

.sold-mask {
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  height: 160rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

/* 锁定状态滚动提示 */
.lock-scroll {
  background: #fff3cd;
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #ffc107;
}

.lock-text {
  font-size: 24rpx;
  color: #856404;
}

.lock-notice {
  background: #d4edda;
  padding: 10rpx 20rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
}

.lock-notice-text {
  font-size: 24rpx;
  color: #155724;
}

.btn-disabled {
  background: #ccc;
  color: #666;
  flex: 1;
  margin: 0;
  font-size: 28rpx;
  padding: 22rpx 12rpx;
  line-height: 1.3;
}

.detail-body {
  padding-bottom: 24rpx;
}

.detail-body.has-bar {
  padding-bottom: calc(240rpx + env(safe-area-inset-bottom));
}

.errand-bar .action-btn {
  flex: 1;
  min-width: 0;
}

.title-row {
  align-items: flex-start;
  padding: 24rpx 24rpx 0;
  gap: 16rpx;
}

.detail-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
}

.detail-price {
  display: block;
  padding: 12rpx 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #e85d4c;
}

.tag-info {
  margin-left: 24rpx;
}

.seller-card {
  margin-top: 16rpx;
  align-items: center;
}

.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8f0f8, #d4e4f7);
  margin-right: 20rpx;
  font-size: 40rpx;
}

.seller-name {
  font-size: 28rpx;
  font-weight: 500;
}

.credit-caption {
  margin-top: 4rpx;
}

.credit-caption.excellent,
.credit-caption.good {
  color: #26734d;
}

.credit-caption.normal {
  color: #4a7ab8;
}

.credit-caption.warning {
  color: #b7791f;
}

.credit-caption.danger {
  color: #c53030;
}

.section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
  display: block;
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
}

.info-line {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  color: #333;
}

.info-k {
  color: #8a9399;
  margin-right: 16rpx;
}

.contact-section .phone-val {
  color: #4a7ab8;
  font-weight: 500;
}

.copy-hint {
  font-size: 22rpx;
  color: #8a9399;
  margin-left: 12rpx;
}

.runner-block {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef1f5;
}

.runner-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #4a7ab8;
  display: block;
  margin-bottom: 12rpx;
}

.hint-muted {
  font-size: 26rpx;
  color: #8a9399;
  line-height: 1.5;
}

.owner-bar .action-btn.full {
  flex: 1;
}

.owner-bar .action-btn.danger {
  color: #e85d4c;
  border-color: #f0d0cc;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 12rpx;
  box-sizing: border-box;
}

.action-bar.flex-row {
  flex-direction: row;
}

.action-bar-buyer {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-bar-main {
  width: 100%;
  gap: 16rpx;
}

.action-bar-main .cart-btn,
.action-bar-main .buy-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  font-size: 28rpx;
  padding: 22rpx 12rpx;
  line-height: 1.3;
}

.action-bar-main .buy-btn {
  flex: 1.1;
}

.action-bar-sub {
  width: 100%;
  justify-content: center;
  align-items: center;
  gap: 56rpx;
  padding: 4rpx 0 2rpx;
}

.sub-link-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #4a7ab8;
}

.sub-link-muted {
  color: #8a9399;
}

.sub-disabled {
  opacity: 0.45;
  pointer-events: none;
}

.action-btn {
  flex: 1;
  margin: 0;
  font-size: 26rpx;
  padding: 20rpx 12rpx;
  min-width: 0;
}

.action-btn.main {
  flex: 1.2;
}

.detail-loading {
  min-height: 60vh;
}
/* 原有样式... */
.lock-buyers-section {
  background: #f0f9ff;
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #b3d8ff;
  font-size: 24rpx;
}
.lock-buyers-title {
  font-weight: 600;
  color: #2c3e50;
  display: block;
  margin-bottom: 6rpx;
}
.lock-buyer-item {
  display: block;
  color: #4a7ab8;
  margin-bottom: 4rpx;
}

.seller-lock-panel {
  margin: 16rpx 24rpx 0;
  padding: 20rpx;
}

.seller-lock-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8rpx;
}

.seller-lock-hint {
  display: block;
  font-size: 24rpx;
  color: #856404;
  margin-bottom: 16rpx;
}

.seller-lock-item {
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #eef1f5;
}

.seller-lock-name {
  font-size: 28rpx;
  color: #2c3e50;
}

.seller-lock-time {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.action-bar-tip { font-size: 24rpx; color: #888; flex: 1; }
