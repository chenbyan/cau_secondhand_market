<view class="notices-page page-safe-bottom">
  <view wx:if="{{loading}}" class="loading-wrap flex-center">
    <text class="text-muted">加载中...</text>
  </view>

  <block wx:else>
    <view wx:if="{{!notices.length}}" class="empty-state flex-col flex-center">
      <text class="empty-illus">📭</text>
      <text class="empty-title">暂无系统通知</text>
    </view>

    <view
      wx:for="{{notices}}"
      wx:key="objectId"
      class="notice-row card-flat {{!item.read ? 'unread' : ''}}"
      data-case-key="{{item.caseKey}}"
      data-type="{{item.type}}"
      bindtap="onTapNotice"
    >
      <view class="notice-header flex-row flex-between">
        <view class="notice-type-tag">{{item.typeLabel}}</view>
        <text class="notice-time">{{item.timeText}}</text>
      </view>
      <text class="notice-title">{{item.title}}</text>
      <text class="notice-content text-muted">{{item.content}}</text>
      <view wx:if="{{item.caseKey && item.type !== 'credit_changed'}}" class="notice-link">
        <text class="link-text">查看案卷 ›</text>
      </view>
    </view>
  </block>
</view>
