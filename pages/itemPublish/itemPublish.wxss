.publish-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f2f5f8;
}

.form-scroll {
  flex: 1;
  height: 0;
  padding-bottom: 24rpx;
}

.section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
  display: block;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.req {
  color: #d64545;
}

.picker-val {
  color: #333;
}

.textarea {
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.img-wrap {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
}

.img-thumb {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.img-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  border-radius: 0 16rpx 0 12rpx;
  font-size: 32rpx;
}

.img-add {
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
  border: 2rpx dashed #c5cdd6;
  border-radius: 16rpx;
  background: #f7f9fc;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.footer-bar {
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.footer-btn {
  width: 100%;
  margin: 0;
}
