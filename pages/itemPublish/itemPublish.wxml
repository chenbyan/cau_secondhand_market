<view class="publish-page page-safe-bottom">
  <scroll-view scroll-y class="form-scroll">
    <view class="section card-flat">
      <text class="section-title">商品信息</text>
      <view class="field flex-col">
        <text class="label">标题 <text class="req">*</text></text>
        <input
          class="input-box"
          placeholder="物品名称"
          maxlength="40"
          value="{{form.title}}"
          bindinput="onTitle"
          bindblur="onTitleBlur"
        />
        <text wx:if="{{errors.title}}" class="field-error">{{errors.title}}</text>
      </view>
      <view class="field flex-col">
        <text class="label">分类</text>
        <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
          <view class="input-box picker-val">{{form.category}}</view>
        </picker>
      </view>
      <view class="field flex-col">
        <text class="label">价格（元） <text class="req">*</text></text>
        <input
          class="input-box"
          type="digit"
          placeholder="0.00"
          value="{{form.price}}"
          bindinput="onPrice"
          bindblur="onPriceBlur"
        />
        <text wx:if="{{errors.price}}" class="field-error">{{errors.price}}</text>
      </view>
    </view>

    <view class="section card-flat">
      <text class="section-title">描述信息</text>
      <view class="field flex-col">
        <text class="label">详细描述 <text class="req">*</text></text>
        <textarea
          class="input-box textarea"
          placeholder="成色、交易方式、取货地点等"
          maxlength="500"
          value="{{form.description}}"
          bindinput="onDesc"
          bindblur="onDescBlur"
        />
        <text wx:if="{{errors.description}}" class="field-error">{{errors.description}}</text>
      </view>
    </view>

    <view class="section card-flat">
      <text class="section-title">图片上传</text>
      <text class="text-caption">最多 6 张，首张为封面{{uploading ? '（上传中…）' : ''}}</text>
      <view class="img-grid">
        <block wx:for="{{form.images}}" wx:key="*this">
          <view class="img-wrap">
            <image class="img-thumb" src="{{item}}" mode="aspectFill" />
            <view class="img-del" data-index="{{index}}" catchtap="onRemoveImage">×</view>
          </view>
        </block>
        <view
          wx:if="{{form.images.length < 6}}"
          class="img-add flex-col flex-center"
          bindtap="onAddImage"
        >
          <text class="camera-icon">📷</text>
          <text class="text-caption">添加</text>
        </view>
      </view>
      <text wx:if="{{errors.images}}" class="field-error">{{errors.images}}</text>
    </view>
  </scroll-view>

  <view class="footer-bar">
    <button
      class="btn-primary footer-btn"
      loading="{{submitting}}"
      disabled="{{!canSubmit}}"
      bindtap="onSubmit"
    >{{editId ? '保存修改' : '发布物品'}}</button>
  </view>
</view>
