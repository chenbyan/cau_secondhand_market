.feedback-page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.empty {
  padding: 80rpx 32rpx;
  gap: 24rpx;
}

.error-tip {
  font-size: 28rpx;
  color: #d64545;
  text-align: center;
  line-height: 1.5;
}

.hint-block {
  font-size: 24rpx;
  text-align: center;
  line-height: 1.6;
  padding: 0 16rpx;
}

.ticket-card {
  margin-bottom: 20rpx;
}

.ticket-head {
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.reason {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}

.thumb-row {
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #eef1f5;
}

.card-actions {
  margin-top: 16rpx;
  gap: 16rpx;
}

.cancel-btn,
.link-btn {
  margin: 0;
  width: auto;
  min-width: 140rpx;
  font-size: 26rpx;
}

.tip-banner {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff8e6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #8a6d3b;
  line-height: 1.5;
}

.tag-warn {
  background: #fff3e0;
  color: #e65100;
}

.case-summary {
  margin-bottom: 20rpx;
}

.case-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.decision-box {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f5f8fc;
  border-radius: 12rpx;
  border-left: 6rpx solid #4a7ab8;
}

.decision-box.compact {
  margin-top: 14rpx;
}

.decision-title {
  display: block;
  font-size: 24rpx;
  color: #4a7ab8;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.decision-note {
  display: block;
  margin-top: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin: 8rpx 0 16rpx;
}

.reply-card {
  margin-bottom: 16rpx;
}

.reply-role {
  display: block;
  font-size: 24rpx;
  color: #4a7ab8;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.reply-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.form-card {
  padding: 24rpx;
}

.reason-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.evidence-block {
  margin-top: 24rpx;
}

.evidence-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.img-grid {
  flex-wrap: wrap;
  gap: 16rpx;
}

.img-cell {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.img-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #eef1f5;
}

.img-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.img-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #c5cdd6;
  border-radius: 12rpx;
  background: #f7f9fc;
}

.add-icon {
  font-size: 56rpx;
  color: #8a9399;
  line-height: 1;
}

.submit-btn {
  margin-top: 28rpx;
}

.hint {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  padding: 0 8rpx;
}
