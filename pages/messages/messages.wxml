<view class="msg-page page-safe-bottom">
  <view wx:if="{{!loggedIn}}" class="empty-state flex-col flex-center">
    <text class="empty-illus">💬</text>
    <text class="empty-title">登录后查看消息</text>
    <button class="btn-primary empty-action" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view class="msg-tabs flex-row">
      <view
        class="msg-tab {{activeTab === 'all' ? 'active' : ''}}"
        data-tab="all"
        bindtap="onSwitchTab"
      >全部</view>
      <view
        class="msg-tab {{activeTab === 'notice' ? 'active' : ''}}"
        data-tab="notice"
        bindtap="onSwitchTab"
      >
        通知
        <text wx:if="{{unreadCount > 0}}" class="tab-badge">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
      </view>
      <view
        class="msg-tab {{activeTab === 'chat' ? 'active' : ''}}"
        data-tab="chat"
        bindtap="onSwitchTab"
      >聊天</view>
      <view wx:if="{{unreadCount > 0}}" class="mark-read" bindtap="onMarkAllRead">全部已读</view>
    </view>

    <view wx:if="{{loading}}" class="loading-wrap flex-center">
      <text class="text-muted">加载中...</text>
    </view>

    <block wx:else>
      <!-- 通知 -->
      <view wx:if="{{activeTab === 'all' || activeTab === 'notice'}}" class="section">
        <view wx:if="{{activeTab === 'all'}}" class="section-head">系统通知</view>
        <view wx:if="{{!notices.length}}" class="section-empty text-muted">暂无通知</view>
        <view
          wx:for="{{notices}}"
          wx:for-index="noticeIdx"
          wx:key="objectId"
          class="notice-card card-flat flex-row {{item.read ? '' : 'unread'}}"
          hover-class="notice-card-hover"
          data-index="{{noticeIdx}}"
          bindtap="onOpenNotice"
        >
          <view class="notice-icon flex-center">!</view>
          <view class="notice-body flex-col">
            <view class="flex-row flex-between">
              <text class="notice-title">{{item.title}}</text>
              <text class="room-time">{{item.timeText}}</text>
            </view>
            <text class="notice-content">{{item.content}}</text>
            <text class="room-tag">{{item.typeLabel}}</text>
          </view>
          <view wx:if="{{!item.read}}" class="dot"></view>
        </view>
      </view>

      <!-- 聊天 -->
      <view wx:if="{{activeTab === 'all' || activeTab === 'chat'}}" class="section">
        <view wx:if="{{activeTab === 'all'}}" class="section-head">聊天会话</view>
        <view wx:if="{{!rooms.length}}" class="section-empty text-muted">暂无会话</view>
        <view wx:else class="room-list">
          <view
            wx:for="{{rooms}}"
            wx:key="objectId"
            class="room-card card-flat flex-row"
            data-room-id="{{item.objectId}}"
            data-item-id="{{item.itemId}}"
            bindtap="onOpenRoom"
          >
            <view class="room-avatar flex-center">{{item.avatarText}}</view>
            <view class="room-body flex-col">
              <view class="flex-row flex-between">
                <text class="room-title">{{item.title}}</text>
                <text class="room-time">{{item.timeText}}</text>
              </view>
              <text class="room-preview">{{item.lastMsg || '点击进入群聊'}}</text>
              <text class="room-tag">{{item.tagText}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'all' && !notices.length && !rooms.length}}" class="empty-state flex-col flex-center">
        <text class="empty-illus">📭</text>
        <text class="empty-title">暂无消息</text>
        <text class="text-muted text-center">举报/申诉动态与聊天会话将显示在这里</text>
      </view>
    </block>
  </block>
</view>
