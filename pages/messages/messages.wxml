<view class="msg-page page-safe-bottom">
  <view wx:if="{{!loggedIn}}" class="empty-state flex-col flex-center">
    <text class="empty-illus">💬</text>
    <text class="empty-title">登录后查看消息</text>
    <button class="btn-primary empty-action" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view class="msg-tabs flex-row">
      <view class="msg-tab {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="onSwitchTab">全部</view>
      <view class="msg-tab {{activeTab === 'notice' ? 'active' : ''}}" data-tab="notice" bindtap="onSwitchTab">
        通知
        <text wx:if="{{noticeUnreadCount > 0}}" class="tab-badge">{{noticeUnreadCount > 99 ? '99+' : noticeUnreadCount}}</text>
      </view>
      <view class="msg-tab {{activeTab === 'chat' ? 'active' : ''}}" data-tab="chat" bindtap="onSwitchTab">
        聊天
        <text wx:if="{{chatUnreadCount > 0}}" class="tab-badge">{{chatUnreadCount > 99 ? '99+' : chatUnreadCount}}</text>
      </view>
      <view wx:if="{{totalUnread > 0}}" class="mark-read" bindtap="onMarkAllRead">全部已读</view>
    </view>

    <view wx:if="{{loading}}" class="loading-wrap flex-center">
      <text class="text-muted">加载中...</text>
    </view>

    <block wx:else>
      <!-- 通知区 -->
      <view wx:if="{{activeTab === 'all' || activeTab === 'notice'}}" class="section">
        <view wx:if="{{activeTab === 'all'}}" class="section-head">通知</view>

        <!-- 后台通知分类：信用分变更 / 商品下架 / 纠纷 -->
        <view
          wx:for="{{noticeGroups}}"
          wx:key="category"
          class="msg-row card-flat flex-row {{item.unread > 0 ? 'unread' : ''}}"
          hover-class="msg-row-hover"
          data-category="{{item.category}}"
          bindtap="onOpenNoticeGroup"
        >
          <view class="row-avatar {{item.avatarClass}} flex-center">{{item.avatarText}}</view>
          <view class="row-body flex-col">
            <view class="flex-row flex-between">
              <text class="row-title">{{item.title}}</text>
              <text class="row-time">{{item.timeText}}</text>
            </view>
            <text class="row-preview">{{item.lastTitle || item.lastContent}}</text>
            <text class="row-tag">{{item.tagText}}</text>
          </view>
          <view wx:if="{{item.unread > 0}}" class="badge">{{item.unread > 99 ? '99+' : item.unread}}</view>
        </view>

        <!-- 订单状态通知（每个订单一个框） -->
        <view
          wx:for="{{orderGroups}}"
          wx:key="orderId"
          class="msg-row card-flat flex-row {{item.unread > 0 ? 'unread' : ''}}"
          hover-class="msg-row-hover"
          data-order-id="{{item.orderId}}"
          data-index="{{index}}"
          bindtap="onOpenOrderGroup"
        >
          <view class="row-avatar order-avatar flex-center">订</view>
          <view class="row-body flex-col">
            <view class="flex-row flex-between">
              <text class="row-title">订单通知</text>
              <text class="row-time">{{item.timeText}}</text>
            </view>
            <text class="row-preview">{{item.lastTitle || item.lastContent}}</text>
            <text class="row-tag">点击查看订单详情</text>
          </view>
          <view wx:if="{{item.unread > 0}}" class="badge">{{item.unread > 99 ? '99+' : item.unread}}</view>
        </view>

        <view wx:if="{{!noticeGroups.length && !orderGroups.length}}" class="section-empty text-muted">暂无通知</view>
      </view>

      <!-- 聊天区 -->
      <view wx:if="{{activeTab === 'all' || activeTab === 'chat'}}" class="section">
        <view wx:if="{{activeTab === 'all'}}" class="section-head">聊天</view>
        <view wx:if="{{!rooms.length}}" class="section-empty text-muted">暂无会话</view>
        <view
          wx:for="{{rooms}}"
          wx:key="objectId"
          class="msg-row card-flat flex-row"
          hover-class="msg-row-hover"
          data-room-id="{{item.objectId}}"
          data-item-id="{{item.itemId}}"
          bindtap="onOpenRoom"
        >
          <view class="row-avatar room-avatar flex-center">{{item.avatarText}}</view>
          <view class="row-body flex-col">
            <view class="flex-row flex-between">
              <text class="row-title">{{item.title}}</text>
              <text class="row-time">{{item.timeText}}</text>
            </view>
            <text class="row-preview">{{item.lastMsg || '点击进入群聊'}}</text>
            <text class="row-tag">{{item.tagText}}</text>
          </view>
          <view wx:if="{{item.unread > 0}}" class="badge">{{item.unread > 99 ? '99+' : item.unread}}</view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'all' && !noticeGroups.length && !orderGroups.length && !rooms.length}}" class="empty-state flex-col flex-center">
        <text class="empty-illus">📭</text>
        <text class="empty-title">暂无消息</text>
        <text class="text-muted text-center">订单通知与聊天会话将显示在这里</text>
      </view>
    </block>
  </block>
</view>
