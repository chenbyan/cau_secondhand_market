<view class="my-page page-safe-bottom">
  <view class="profile-hero">
    <view class="user-card" bindtap="onUserCardTap">
      <block wx:if="{{loggedIn}}">
        <view class="flex-row user-row">
          <view class="avatar-wrap">
            <image class="avatar" src="{{user.avatarDisplay || user.avatarUrl || defaultAvatar}}" mode="aspectFill" />
            <view wx:if="{{user.campusVerified}}" class="avatar-badge">✓</view>
          </view>
          <view class="user-meta flex-col">
            <text class="nickname">{{user.nickName || '未设置昵称'}}</text>
            <text class="user-status">{{statusText}}</text>
            <view class="credit-row flex-row">
              <text class="credit-label">信用分</text>
              <view class="credit-bar">
                <view class="credit-fill" style="width: {{creditPercent}}%;"></view>
              </view>
              <text class="credit-num">{{creditScore}}</text>
            </view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="flex-row user-row">
          <view class="avatar-wrap avatar-guest">
            <text class="guest-icon">🎓</text>
          </view>
          <view class="user-meta flex-col">
            <text class="nickname">点击登录</text>
            <text class="text-muted">登录后管理发布与订单</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="menu card">
    <view class="cell flex-row" bindtap="goMyItems" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-publish-list"></view>
      <text class="cell-text">我的发布</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goOrdersBuy" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-order-buy"></view>
      <text class="cell-text">我买到的</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goOrdersSell" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-order-sell"></view>
      <text class="cell-text">我卖出的</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goOrdersErrand" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-order-sell"></view>
      <text class="cell-text">跑腿接单</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goMyCart" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-cart"></view>
      <text class="cell-text">购物车</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goMyBrowse" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-order-buy"></view>
      <text class="cell-text">浏览记录</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goCreditRecords" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-credit"></view>
      <text class="cell-text">信用明细</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goSetting" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-setting"></view>
      <text class="cell-text">个人设置</text>
      <text class="cell-arrow">›</text>
    </view>
    <view wx:if="{{user.campusVerified}}" class="cell flex-row disabled">
      <view class="cell-icon icon-box icon-campus"></view>
      <text class="cell-text">校园认证（已完成）</text>
      <text class="tag-success">已认证</text>
    </view>
    <view
      wx:elif="{{user.campusVerifySt === 'PENDING'}}"
      class="cell flex-row"
      bindtap="goCampus"
      hover-class="cell-hover"
    >
      <view class="cell-icon icon-box icon-campus"></view>
      <text class="cell-text">校园认证</text>
      <text class="tag-warning">审核中</text>
    </view>
    <view
      wx:elif="{{user.campusVerifySt === 'REJECTED'}}"
      class="cell flex-row"
      bindtap="goCampus"
      hover-class="cell-hover"
    >
      <view class="cell-icon icon-box icon-campus"></view>
      <text class="cell-text">校园认证</text>
      <text class="tag-danger">未通过</text>
    </view>
    <view wx:else class="cell flex-row" bindtap="goCampus" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-campus"></view>
      <text class="cell-text">校园认证</text>
      <text class="cell-arrow">›</text>
    </view>
  </view>

  <view class="menu card menu-secondary">
    <view class="cell flex-row" bindtap="goReportInbox" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-campus"></view>
      <text class="cell-text">收到的举报</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goFeedback" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-about"></view>
      <text class="cell-text">我的申诉/举报</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell flex-row" bindtap="goAbout" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-about"></view>
      <text class="cell-text">关于我们</text>
      <text class="cell-arrow">›</text>
    </view>
    <!-- 新增：智能客服 -->
    <view class="cell flex-row" bindtap="goToAiChat" hover-class="cell-hover">
      <view class="cell-icon icon-box icon-ai"></view>
      <text class="cell-text">智能客服</text>
      <text class="cell-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{loggedIn}}" class="logout-wrap">
    <button class="btn-logout" bindtap="onLogout">退出登录</button>
  </view>
</view>
