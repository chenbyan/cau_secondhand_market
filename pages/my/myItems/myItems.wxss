.items-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f2f5f8;
}

.publish-tabs {
  background: #fff;
  padding: 16rpx 24rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.pub-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #8a9399;
  position: relative;
}

.pub-tab.active {
  color: #4a7ab8;
  font-weight: 600;
}

.pub-tab.active::after {
  content: '';
  position: absolute;
  left: 25%;
  right: 25%;
  bottom: 0;
  height: 6rpx;
  background: #4a7ab8;
  border-radius: 4rpx;
}

.status-scroll {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #fff;
  margin-bottom: 8rpx;
}

.status-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: #f7f9fc;
  border-radius: 28rpx;
}

.status-chip.active {
  color: #fff;
  background: #4a7ab8;
}

.list-wrap {
  flex: 1;
  height: 0;
}

.item-card {
  margin: 16rpx 24rpx;
  padding: 0;
  overflow: hidden;
}

.card-body:active {
  background: #f7f9fc;
}

.thumb {
  width: 168rpx;
  height: 168rpx;
  border-radius: 16rpx;
  margin: 20rpx;
  background: linear-gradient(135deg, #e8f0f8, #eef1f5);
  flex-shrink: 0;
}

.info {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 0;
  min-width: 0;
}

.title {
  font-size: 30rpx;
  font-weight: 500;
  color: #2c3e50;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-hint {
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.price {
  color: #e85d4c;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.time {
  margin-top: 6rpx;
}

.tag-info {
  margin-top: 10rpx;
  align-self: flex-start;
}

.actions {
  padding: 0 20rpx 20rpx;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn-action {
  margin: 0;
  background: #4a7ab8;
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  border: none;
}

.btn-action.outline {
  background: #fff;
  color: #4a7ab8;
  border: 2rpx solid #4a7ab8;
}

.btn-action.danger {
  background: #fff5f5;
  color: #d64545;
  border: 2rpx solid #d64545;
}

.action-icon {
  margin-right: 4rpx;
}

.state {
  padding: 40rpx;
}

.empty {
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-btn {
  margin-top: 32rpx;
  width: 280rpx;
}
