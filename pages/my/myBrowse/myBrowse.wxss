.browse-page {
  min-height: 100vh;
  background: #f2f5f8;
}

.browse-toolbar {
  padding: 24rpx 28rpx 8rpx;
}

.browse-tip {
  font-size: 24rpx;
}

.clear-link {
  font-size: 26rpx;
  color: #4a7ab8;
}

.list-wrap {
  height: calc(100vh - 80rpx);
  padding: 16rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.browse-row {
  margin-bottom: 20rpx;
  padding: 20rpx;
  align-items: center;
}

.browse-ended .thumb {
  opacity: 0.72;
}

.thumb-wrap {
  position: relative;
  flex-shrink: 0;
}

.thumb-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 6rpx 0;
  font-size: 22rpx;
  color: #fff;
  text-align: center;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 0 0 12rpx 12rpx;
}

.title-row {
  align-items: flex-start;
  gap: 12rpx;
}

.status-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}

.thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.title {
  font-size: 30rpx;
  color: #222;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price {
  margin-top: 8rpx;
  color: #e54545;
  font-size: 28rpx;
  font-weight: 600;
}

.time {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.del-btn {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.empty {
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-btn {
  margin-top: 24rpx;
  width: 240rpx;
}

.state {
  padding: 80rpx 0;
}
