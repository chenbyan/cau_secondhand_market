.cart-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.list-wrap {
  flex: 1;
  padding: 20rpx;
}

.cart-item-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 0 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;   /* 让删除按钮不破坏圆角 */
}

.checkbox-col {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 10rpx;
}

.checkbox-text {
  font-size: 40rpx;
}

.swipe-wrap {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.swipe-inner {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
  transition: transform 0.2s;
}

/* 删除按钮改为普通 flex 子元素 */
.del-btn {
  width: 120rpx;
  height: 100%;             /* 自适应行高 */
  background: #e74c3c;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  /* 不再需要绝对定位 */
  position: static;         /* 确保覆盖任何残留 */
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  justify-content: space-between;
  padding: 8rpx 0;
}

.title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price {
  font-size: 32rpx;
  color: #c45b3e;
  font-weight: bold;
}

.seller {
  font-size: 24rpx;
  color: #999;
}

/* 底部结算栏 */
.bottom-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  align-items: center;
  display: flex;
  flex-shrink: 0;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all .checkbox-text {
  margin-right: 8rpx;
}

.total {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.total .price {
  color: #c45b3e;
  font-weight: bold;
}

.settlement-btn {
  width: 160rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
  padding: 0;
  border-radius: 35rpx;
}

/* 空状态 */
.empty {
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-btn {
  margin-top: 30rpx;
  width: 200rpx;
}