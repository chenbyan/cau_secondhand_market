.setting-page {
  padding-bottom: 48rpx;
}

.required-mark {
  color: #c0392b;
  font-size: 28rpx;
}

.form-card {
  margin-top: 24rpx;
}

.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.field.flex-col {
  align-items: stretch;
}

.field:last-child {
  border-bottom: none;
}

.label {
  width: 180rpx;
  color: #666666;
  font-size: 28rpx;
}

.preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-left: auto;
  background: linear-gradient(135deg, #e8f0f8, #eef1f5);
}

.upload-hint {
  font-size: 22rpx;
  color: #4a7ab8;
  margin-left: 16rpx;
}

.input {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
}

.picker-val {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
}

.readonly-val {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  align-items: center;
  justify-content: space-between;
}

.uid-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
  font-family: monospace;
}

.readonly-field .copy-hint {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.save-wrap {
  margin: 40rpx 24rpx;
}

.save-btn {
  width: 100%;
}
