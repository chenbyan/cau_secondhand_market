.my-page {
  padding-bottom: 48rpx;
}

.user-card {
  margin-top: 24rpx;
}

.user-row {
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #eee;
}

.user-meta {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tags-row {
  gap: 16rpx;
}

.campus-tap {
  padding: 0;
}

.credit {
  margin-left: 8rpx;
}

.menu {
  margin-top: 24rpx;
}

.cell {
  padding: 28rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cell:last-child {
  border-bottom: none;
}

.cell-icon {
  width: 56rpx;
  font-size: 32rpx;
}

.cell-text {
  flex: 1;
  font-size: 30rpx;
}

.cell-arrow {
  color: #cccccc;
  font-size: 40rpx;
}

.disabled {
  opacity: 0.5;
}

.logout-wrap {
  margin: 48rpx 24rpx;
}

.logout-btn {
  width: 100%;
}
