.credit-page {
  min-height: 100vh;
  background: #f2f5f8;
}

.summary-band {
  padding: 28rpx 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e8edf3;
}

.score-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.score-num {
  font-size: 64rpx;
  font-weight: 700;
  color: #2c3e50;
}

.score-label {
  font-size: 28rpx;
  font-weight: 600;
}

.score-label.excellent,
.score-label.good {
  color: #26734d;
}

.score-label.normal {
  color: #4a7ab8;
}

.score-label.warning {
  color: #b7791f;
}

.score-label.danger {
  color: #c53030;
}

.score-bar {
  height: 16rpx;
  border-radius: 999rpx;
  background: #e8edf3;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #4a7ab8;
}

.score-fill.excellent,
.score-fill.good {
  background: #2f9e62;
}

.score-fill.warning {
  background: #d69e2e;
}

.score-fill.danger {
  background: #e85d4c;
}

.record-list {
  padding: 20rpx 24rpx 40rpx;
}

.record-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
  border: 1rpx solid #e8edf3;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.record-source {
  font-size: 24rpx;
  color: #4a7ab8;
  font-weight: 600;
}

.record-time {
  font-size: 22rpx;
  color: #8a9399;
}

.record-reason {
  display: block;
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.45;
}

.record-score {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a9399;
}

.record-delta {
  min-width: 84rpx;
  text-align: right;
  font-size: 36rpx;
  font-weight: 700;
}

.record-delta.plus {
  color: #1a7f37;
}

.record-delta.minus {
  color: #c53030;
}

.record-delta.zero {
  color: #8a9399;
}

.empty-state,
.loading-tip {
  padding: 44rpx 0;
  text-align: center;
}
