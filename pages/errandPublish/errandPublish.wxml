<view class="publish-page page-safe-bottom">
  <scroll-view scroll-y class="form-scroll">
    <view class="tip-bar card-flat">
      <text class="tip-text">发布后为「未接单」；有同学接单后变为「已接单」；您在「已接单」时可点「标记完成」。</text>
    </view>

    <view class="section card-flat">
      <text class="section-title">任务信息</text>
      <view class="field flex-col">
        <text class="label">任务标题 <text class="req">*</text></text>
        <input
          class="input-box"
          placeholder="如：东区快递代取、食堂带饭"
          maxlength="40"
          value="{{form.title}}"
          bindinput="onTitle"
          bindblur="onTitleBlur"
        />
        <text wx:if="{{errors.title}}" class="field-error">{{errors.title}}</text>
      </view>
      <view class="field flex-col">
        <text class="label">跑腿类型</text>
        <picker mode="selector" range="{{errandCategories}}" value="{{errandCategoryIndex}}" bindchange="onErrandCategoryChange">
          <view class="input-box picker-val">{{form.errandCategory}}</view>
        </picker>
      </view>
      <view class="field flex-col">
        <text class="label">赏金（元） <text class="req">*</text></text>
        <view class="reward-row flex-row">
          <input
            class="input-box flex-1"
            type="digit"
            placeholder="愿意支付的报酬"
            value="{{form.reward}}"
            bindinput="onReward"
            bindblur="onRewardBlur"
          />
        </view>
        <view class="quick-tags flex-row">
          <text
            wx:for="{{rewardPresets}}"
            wx:key="*this"
            class="quick-tag"
            data-val="{{item}}"
            bindtap="onRewardPreset"
          >¥{{item}}</text>
        </view>
        <text wx:if="{{errors.reward}}" class="field-error">{{errors.reward}}</text>
      </view>
    </view>

    <view class="section card-flat">
      <text class="section-title">取送路线</text>
      <view class="field flex-col">
        <text class="label">取件地点 <text class="req">*</text></text>
        <input
          class="input-box"
          placeholder="快递站、教学楼、宿舍楼下等"
          value="{{form.pickupAddr}}"
          bindinput="onPickup"
          bindblur="onPickupBlur"
        />
        <view class="quick-tags flex-row">
          <text
            wx:for="{{pickupPresets}}"
            wx:key="*this"
            class="quick-tag"
            data-val="{{item}}"
            bindtap="onPickupPreset"
          >{{item}}</text>
        </view>
        <text wx:if="{{errors.pickupAddr}}" class="field-error">{{errors.pickupAddr}}</text>
      </view>
      <view class="field flex-col">
        <text class="label">送达地点 <text class="req">*</text></text>
        <input
          class="input-box"
          placeholder="送到哪间宿舍/哪个地点"
          value="{{form.deliveryAddr}}"
          bindinput="onDelivery"
          bindblur="onDeliveryBlur"
        />
        <text wx:if="{{errors.deliveryAddr}}" class="field-error">{{errors.deliveryAddr}}</text>
      </view>
    </view>

    <view class="section card-flat">
      <text class="section-title">时间与说明</text>
      <view class="field flex-col">
        <text class="label">期望完成时间 <text class="req">*</text></text>
        <view class="datetime-row flex-row">
          <picker mode="date" value="{{deadlineDate}}" start="{{minDate}}" bindchange="onDeadlineDate">
            <view class="input-box picker-half">{{deadlineDate || '选择日期'}}</view>
          </picker>
          <picker mode="time" value="{{deadlineTime}}" bindchange="onDeadlineTime">
            <view class="input-box picker-half">{{deadlineTime || '选择时间'}}</view>
          </picker>
        </view>
        <text wx:if="{{errors.deadline}}" class="field-error">{{errors.deadline}}</text>
      </view>
      <view class="field flex-col">
        <text class="label">任务说明 <text class="req">*</text></text>
        <textarea
          class="input-box textarea"
          placeholder="物品说明、联系方式、注意事项等"
          maxlength="500"
          value="{{form.description}}"
          bindinput="onDesc"
          bindblur="onDescBlur"
        />
        <text wx:if="{{errors.description}}" class="field-error">{{errors.description}}</text>
      </view>
      <view class="field flex-col">
        <text class="label">联系电话（选填）</text>
        <input
          class="input-box"
          type="number"
          maxlength="11"
          placeholder="便于接单同学联系"
          value="{{form.contactPhone}}"
          bindinput="onPhone"
        />
      </view>
    </view>

    <view class="section card-flat">
      <text class="section-title">附图（可选，最多 3 张）</text>
      <view class="img-grid">
        <block wx:for="{{form.images}}" wx:key="*this">
          <view class="img-wrap">
            <image class="img-thumb" src="{{item}}" mode="aspectFill" />
            <view class="img-del" data-index="{{index}}" catchtap="onRemoveImage">×</view>
          </view>
        </block>
        <view wx:if="{{form.images.length < 3}}" class="img-add flex-col flex-center" bindtap="onAddImage">
          <text class="camera-icon">📷</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer-bar">
    <button
      class="btn-primary footer-btn"
      loading="{{submitting}}"
      disabled="{{!canSubmit}}"
      bindtap="onSubmit"
    >{{editId ? '保存修改' : '发布跑腿'}}</button>
  </view>
</view>
