.review-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.state {
  padding-top: 120rpx;
}

.review-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
}

.title {
  display: block;
  color: #243447;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.meta {
  color: #6b7785;
  font-size: 26rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.section-title {
  display: block;
  color: #243447;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.rating-row {
  display: flex;
  gap: 16rpx;
}

.rating-item {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 8rpx;
  background: #eef3f8;
  color: #2d5a8e;
  font-size: 30rpx;
  font-weight: 600;
}

.rating-item.active {
  background: #2d5a8e;
  color: #fff;
}

.review-input {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 8rpx;
  padding: 18rpx;
  color: #243447;
  font-size: 28rpx;
}

.submit-btn {
  margin-top: 16rpx;
}
