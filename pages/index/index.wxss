  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-empty {
  color: #8a9399;
  font-size: 25rpx;
  padding: 34rpx 28rpx;
}

.goods-list {
  padding-bottom: 2rpx;
}

.goods-card {
  display: flex;
  flex-direction: row;
  padding: 20rpx;
}

.goods-thumb {
  width: 168rpx;
  height: 168rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #e8f0f8, #f0f4f8);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
  justify-content: space-between;
  padding: 4rpx 0;
}

.goods-title-row {
  align-items: flex-start;
  gap: 10rpx;
}

.goods-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-desc,
.route-text {
  display: -webkit-box;
  margin-top: 8rpx;
  color: #66717b;
  font-size: 23rpx;
  line-height: 1.35;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.route-text {
  color: #4a7ab8;
}

.goods-bottom {
  align-items: flex-end;
  gap: 12rpx;
  margin-top: 12rpx;
}

.price-line {
  align-items: baseline;
  flex-shrink: 0;
}

.price-label {
  color: #8a9399;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.goods-price {
  font-size: 31rpx;
  font-weight: 700;
  color: #e85d4c;
}

.goods-tags {
  gap: 8rpx;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.tag-parttime {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  color: #1a7f37;
  background: #e6f7ea;
  font-size: 22rpx;
}

.footer-hint {
  padding: 24rpx;
  font-size: 22rpx;
}