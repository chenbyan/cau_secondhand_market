.order-detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.status-bar {
  justify-content: center;
  margin-bottom: 20rpx;
}

.status-tag {
  font-size: 32rpx;
  font-weight: bold;
  padding: 8rpx 30rpx;
  border-radius: 30rpx;
}

.tag-PENDING_CONFIRM { background: #fff3cd; color: #856404; }
.tag-IN_TRADING     { background: #d4edda; color: #155724; }
.tag-SHIPPED        { background: #d4edda; color: #155724; }
.tag-COMPLETED      { background: #d4edda; color: #155724; }
.tag-CANCELLED      { background: #f8d7da; color: #721c24; }

.goods-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.info {
  flex: 1;
}

.title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.price {
  font-size: 32rpx;
  color: #c45b3e;
  font-weight: bold;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-row {
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}
.info-row:last-child {
  border-bottom: none;
}

.review-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.review-title {
  color: #333;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.review-tip {
  display: block;
  margin-bottom: 12rpx;
}

.review-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid #eee;
}

.review-role {
  color: #2d5a8e;
  font-size: 26rpx;
  font-weight: 600;
}

.review-rating {
  color: #c45b3e;
  font-size: 26rpx;
}

.review-content {
  width: 100%;
  color: #333;
  font-size: 26rpx;
  line-height: 1.6;
}

.label {
  color: #999;
  font-size: 28rpx;
}

.value {
  color: #333;
  font-size: 28rpx;
  max-width: 400rpx;
  word-break: break-all;
}

.action-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-primary, .btn-outline {
  width: 500rpx;
  margin-bottom: 0;
}
.remind-box {
  background: #fff8e1;
  border-left: 8rpx solid #f5a623;
  padding: 15rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}
.remind-text {
  font-size: 28rpx;
  color: #b8860b;
}

.errand-code-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.errand-code-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.errand-code-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-top: 1rpx solid #eee;
}

.code-row-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.code-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.code-status {
  font-size: 24rpx;
}

.code-ok {
  color: #28a745;
}

.code-pending {
  color: #999;
}

.code-hint-block {
  margin-top: 8rpx;
}

.code-value-display {
  font-size: 36rpx;
  color: #2d5a8e;
  font-weight: 700;
  letter-spacing: 6rpx;
  display: block;
  margin-bottom: 6rpx;
}

.code-hint {
  font-size: 22rpx;
  color: #f5a623;
  display: block;
  line-height: 1.5;
}

.code-verified-tag {
  font-size: 24rpx;
  color: #28a745;
  font-weight: 600;
}

.btn-code {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #2d5a8e;
  color: #fff;
  line-height: 1.6;
  min-height: unset;
  height: auto;
}

.btn-code-verify {
  background: #c45b3e;
}

.code-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-modal {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx 30rpx;
  width: 580rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.code-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
}

.code-modal-input {
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  color: #333;
}

.code-modal-btns {
  display: flex;
  gap: 20rpx;
}

.code-modal-cancel, .code-modal-ok {
  flex: 1;
  font-size: 28rpx;
}

.frozen-tip {
  font-size: 26rpx;
}

.linked-errand-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #2d5a8e;
}

.linked-errand-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d5a8e;
  margin-bottom: 16rpx;
}

.linked-errand-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.linked-errand-label {
  font-size: 26rpx;
  color: #999;
  min-width: 80rpx;
}

.linked-errand-status {
  font-size: 26rpx;
  font-weight: 500;
}

.status-ON_SALE    { color: #f5a623; }
.status-IN_TRADING { color: #28a745; }
.status-SOLD_OUT   { color: #2d5a8e; }
.status-OFFLINE    { color: #999; }

.linked-errand-empty {
  font-size: 24rpx;
}

.errand-request-btn {
  border-color: #2d5a8e;
  color: #2d5a8e;
}
