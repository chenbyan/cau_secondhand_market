.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(74, 122, 184, 0.1);
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 12rpx;
}

.tab-icon-wrap {
  position: relative;
  margin-bottom: 6rpx;
}

.bar-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: #e85d4c;
  border-radius: 999rpx;
  text-align: center;
  box-sizing: border-box;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 0;
  opacity: 0.45;
}

.tab-icon.active {
  opacity: 1;
}

.icon-home {
  border: 4rpx solid #8a9399;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  box-sizing: border-box;
}

.icon-home.active {
  border-color: #4a7ab8;
  background: rgba(74, 122, 184, 0.12);
}

.icon-my {
  border-radius: 50%;
  border: 4rpx solid #8a9399;
  box-sizing: border-box;
}

.icon-my.active {
  border-color: #4a7ab8;
  background: rgba(74, 122, 184, 0.12);
}

.icon-message {
  border: 4rpx solid #8a9399;
  border-radius: 12rpx;
  box-sizing: border-box;
  position: relative;
}

.icon-message::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 12rpx;
  width: 20rpx;
  height: 12rpx;
  border-top: 3rpx solid #8a9399;
  border-left: 3rpx solid #8a9399;
}

.icon-message.active {
  border-color: #4a7ab8;
  background: rgba(74, 122, 184, 0.12);
}

.icon-message.active::after {
  border-color: #4a7ab8;
}

.tab-text {
  font-size: 22rpx;
}
